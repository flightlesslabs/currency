{
  "name": "@flightlesslabs/currency",
  "version": "0.0.3",
  "license": "MIT",
  "description": "A lightweight TypeScript library providing country and currency mappings, including ISO codes, symbols, and utility functions.",
  "publishConfig": {
    "access": "public"
  },
  "fmt": {
    "useTabs": false,
    "semiColons": true,
    "singleQuote": true,
    "include": ["src/", "scripts/"]
  },
  "exports": "./src/mod.ts",
  "tasks": {
    "docs": "deno doc --html --output=docs src/mod.ts",
    "build": "deno run -A scripts/build_npm.ts"
  },
  "imports": {
    "@deno/dnt": "jsr:@deno/dnt@^0.42.3",
    "@std/assert": "jsr:@std/assert@1"
  }
}
