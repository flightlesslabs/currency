{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",

    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,

    "esModuleInterop": true,
    "resolveJsonModule": true,

    "allowImportingTsExtensions": true,
    "forceConsistentCasingInFileNames": true,

    "lib": ["ES2020", "DOM"],
  },

  "include": ["src/**/*"],

  "exclude": [
    "node_modules",
    "docs",
    "dist",
    "scripts",
    "**/*.test.ts",
    "**/*.spec.ts",
  ],
}
